  endings:
  - id: ending_justice
    title: Justice Served
    description: You successfully identified Morgan as the culprit. The combination
      of the tool manifest, the suspicious timing, and Dr. Chen's testimony proved
      conclusive.
    minimumJudgeTrust: 80
    maximumPenalty: 2
  - id: ending_reasonable_doubt
    title: Reasonable Doubt
    description: While suspicion fell on Morgan, insufficient evidence proved reasonable
      doubt. The case is dismissed, but the prototype remains missing.
    minimumJudgeTrust: 30
    maximumPenalty: 5
  - id: ending_false_accusation
    title: False Accusation
    description: You accused the wrong person. The judge rules in favor of the accused,
      and your credibility is damaged.
    minimumJudgeTrust: 0
    maximumPenalty: 8
